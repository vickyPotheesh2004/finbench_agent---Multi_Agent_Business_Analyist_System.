# ═══════════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/

# ═══════════════════════════════════════════════════════════════════
# Virtual environments — NEVER commit these
# ═══════════════════════════════════════════════════════════════════
venv/
env/
ENV/
.venv/
venv.bak/

# ═══════════════════════════════════════════════════════════════════
# Model caches & large binaries
# ═══════════════════════════════════════════════════════════════════
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.ckpt
*.h5
*.pkl
models/cache/
data/chromadb/
data/bm25_index/
data/*.db
data/*.sqlite
data/*.sqlite3
outputs/
!outputs/.gitkeep

# ═══════════════════════════════════════════════════════════════════
# Downloaded documents (too large; we provide a downloader script)
# ═══════════════════════════════════════════════════════════════════
documents/sec_filings/*.html
documents/sec_filings/*.pdf
documents/uploads/

# ═══════════════════════════════════════════════════════════════════
# IDE / OS
# ═══════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# ═══════════════════════════════════════════════════════════════════
# Logs & test artifacts
# ═══════════════════════════════════════════════════════════════════
*.log
logs/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ═══════════════════════════════════════════════════════════════════
# Environment / secrets
# ═══════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ═══════════════════════════════════════════════════════════════════
# Eval result files (keep latest.md as reference, ignore timestamps)
# ═══════════════════════════════════════════════════════════════════
eval/results/eval_*_*.json
eval/results/eval_*_*.md

# ═══════════════════════════════════════════════════════════════════
# Jupyter
# ═══════════════════════════════════════════════════════════════════
.ipynb_checkpoints/